function showVulnResults(type,target){
  const vulns=VULNS[type]||VULNS.full;
  const critical=vulns.filter(v=>v.sev==='critical').length;
  const high=vulns.filter(v=>v.sev==='high').length;
  const medium=vulns.filter(v=>v.sev==='medium').length;
  const low=vulns.filter(v=>v.sev==='low').length;
  document.getElementById('vscan-summary').innerHTML=`Target: ${target}<br><span style="color:var(--red)">CRITICAL: ${critical}</span> &nbsp; <span style="color:var(--yellow)">HIGH: ${high}</span> &nbsp; <span style="color:var(--cyan)">MEDIUM: ${medium}</span> &nbsp; <span style="color:var(--green)">LOW: ${low}</span><br>Risk Level: ${critical>0?'<span style="color:var(--red)">CRITICAL</span>':high>0?'<span style="color:var(--yellow)">HIGH</span>':'MEDIUM'}`;
  document.getElementById('vuln-results').innerHTML=vulns.map(v=>`<div class="vuln-item vuln-${v.sev}"><strong style="color:${v.sev==='critical'?'var(--red)':v.sev==='high'?'var(--yellow)':v.sev==='medium'?'var(--cyan)':'var(--green)'}">[${v.sev.toUpperCase()}]</strong> ${v.title}<br><span style="color:#aaa">${v.desc}</span><br><span style="color:#00ff41">Fix: ${v.fix}</span></div>`).join('');
  stats.scans++;updateStats();
}

