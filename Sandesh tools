const WORDS=['cyber','hacker','falcon','shield','matrix','ghost','shadow','nexus','storm','viper','phantom','blade','titan','sigma','delta'];
function generatePasswords(){
  const len=parseInt(document.getElementById('pass-len').value)||24;
  const qty=parseInt(document.getElementById('pass-qty').value)||5;
  const mode=document.getElementById('pass-mode').value;
  const upper=document.getElementById('use-upper').checked,lower2=document.getElementById('use-lower').checked;
  const nums=document.getElementById('use-nums').checked,syms=document.getElementById('use-sym').checked;
  let passwords=[];
  for(let q=0;q<qty;q++){
    let pwd='';
    if(mode==='passphrase'){const sep=syms?['!','@','#','$','_'][Math.floor(Math.random()*5)]:'-';pwd=Array.from({length:Math.floor(len/6)||4},()=>{let w=WORDS[Math.floor(Math.random()*WORDS.length)];return upper?w.charAt(0).toUpperCase()+w.slice(1):w;}).join(sep);if(nums)pwd+=Math.floor(Math.random()*9999);}
    else if(mode==='pin'){pwd=Array.from({length:len},()=>Math.floor(Math.random()*10)).join('');}
    else{let c='';if(upper)c+='ABCDEFGHIJKLMNOPQRSTUVWXYZ';if(lower2)c+='abcdefghijklmnopqrstuvwxyz';if(nums)c+='0123456789';if(syms)c+='!@#$%^&*()-_=+[]{}';if(!c)c='abcdefghijklmnopqrstuvwxyz';const arr=new Uint32Array(len);crypto.getRandomValues(arr);pwd=Array.from(arr).map(v=>c[v%c.length]).join('');}
    passwords.push(pwd);
  }
  document.getElementById('pass-output').textContent=passwords.join('\n');
  stats.pass+=qty;updateStats();
  const s=calcStr(passwords[0]);
  document.getElementById('strength-fill').style.cssText='width:'+s.pct+'%;background:'+s.color;
  document.getElementById('strength-label').textContent='STRENGTH: '+s.label;
  document.getElementById('strength-label').style.color=s.color;
}
function calcStr(pwd){
  let score=0;if(pwd.length>=12)score++;if(pwd.length>=20)score++;if(/[A-Z]/.test(pwd))score++;if(/[a-z]/.test(pwd))score++;if(/[0-9]/.test(pwd))score++;if(/[^A-Za-z0-9]/.test(pwd))score++;if(pwd.length>=30)score++;
  const levels=[{min:0,pct:15,color:'#ff003c',label:'VERY WEAK'},{min:2,pct:35,color:'#ff6600',label:'WEAK'},{min:3,pct:55,color:'#ffe600',label:'MODERATE'},{min:5,pct:75,color:'#88ff00',label:'STRONG'},{min:6,pct:100,color:'#00ff41',label:'VERY STRONG'}];
  let level=levels[0];for(const l of levels)if(score>=l.min)level=l;return level;
}
function checkStrength(pwd){
  if(!pwd){['check-fill','check-label','check-details'].forEach(id=>document.getElementById(id).textContent='');document.getElementById('check-fill').style.width='0%';return;}
  const s=calcStr(pwd);
