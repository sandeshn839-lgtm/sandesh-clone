<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sandesh Ethical Hacking Tools</title>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Orbitron:wght@400;700;900&family=VT323&display=swap" rel="stylesheet">
<style>
  :root{--green:#00ff41;--bg:#0a0a0a;--panel:#0d1117;--cyan:#00eeff;--red:#ff003c;--yellow:#ffe600;--glow:0 0 10px #00ff41,0 0 20px #00ff4155;--glow-cyan:0 0 10px #00eeff,0 0 20px #00eeff55;}
  *{margin:0;padding:0;box-sizing:border-box;}
  body{font-family:'Share Tech Mono',monospace;background:var(--bg);color:var(--green);min-height:100vh;overflow-x:hidden;}
  #matrix-canvas{position:fixed;top:0;left:0;width:100%;height:100%;z-index:0;opacity:0.13;pointer-events:none;}
  body::before{content:'';position:fixed;top:0;left:0;width:100%;height:100%;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,255,65,0.02) 2px,rgba(0,255,65,0.02) 4px);z-index:1;pointer-events:none;}
  #login-screen{position:fixed;inset:0;background:#000;z-index:1000;display:flex;align-items:center;justify-content:center;flex-direction:column;}
  .login-box{background:rgba(0,15,0,0.97);border:1px solid var(--green);box-shadow:var(--glow);width:420px;padding:40px 36px;position:relative;}
  .login-box::before{content:'SECURE LOGIN';position:absolute;top:-12px;left:20px;background:#000;padding:0 8px;font-family:'Orbitron',sans-serif;font-size:11px;color:var(--green);letter-spacing:4px;}
  .login-logo{font-family:'Orbitron',sans-serif;font-size:22px;font-weight:900;color:var(--green);text-align:center;text-shadow:var(--glow);margin-bottom:6px;}
  .login-sub{text-align:center;font-size:11px;color:#00ff4188;margin-bottom:28px;letter-spacing:3px;}
  .login-field{margin-bottom:16px;}
  .login-field label{display:block;font-size:11px;color:#00ff4188;margin-bottom:6px;letter-spacing:2px;}
  .login-field input{width:100%;background:#001500;border:1px solid #00ff4155;color:var(--green);font-family:'Share Tech Mono',monospace;font-size:14px;padding:10px 14px;outline:none;}
  .login-field input:focus{border-color:var(--green);box-shadow:0 0 8px #00ff4144;}
  .login-btn{width:100%;background:transparent;border:1px solid var(--green);color:var(--green);font-family:'Orbitron',sans-serif;font-size:13px;letter-spacing:4px;padding:12px;cursor:pointer;transition:all .2s;margin-top:8px;}
  .login-btn:hover{background:var(--green);color:#000;}
  .gmail-btn{width:100%;background:transparent;border:1px solid #4285f4;color:#4285f4;font-family:'Share Tech Mono',monospace;font-size:13px;padding:11px;cursor:pointer;transition:all .2s;margin-top:10px;display:flex;align-items:center;justify-content:center;gap:10px;}
  .gmail-btn:hover{background:#4285f422;}
  .login-status{text-align:center;font-size:12px;color:var(--cyan);margin-top:14px;min-height:18px;}
  #app{position:relative;z-index:2;display:none;}
  .header{background:rgba(0,10,0,0.95);border-bottom:1px solid #00ff4133;padding:10px 20px;display:flex;align-items:center;gap:14px;position:sticky;top:0;z-index:100;backdrop-filter:blur(8px);}
  .header-logo{font-family:'Orbitron',sans-serif;font-size:14px;font-weight:900;color:var(--green);text-shadow:var(--glow);flex:1;}
  .header-logo span{color:var(--cyan);}
  .user-badge{background:#001f00;border:1px solid #00ff4144;padding:4px 12px;font-size:11px;color:var(--green);}
  .logout-btn{background:transparent;border:1px solid var(--red);color:var(--red);font-family:'Share Tech Mono',monospace;font-size:11px;padding:4px 10px;cursor:pointer;}
  .nav{display:flex;background:rgba(0,5,0,0.9);border-bottom:1px solid #00ff4122;overflow-x:auto;}
  .nav-btn{background:transparent;border:none;border-right:1px solid #00ff4122;color:#00ff4166;font-family:'Share Tech Mono',monospace;font-size:11px;padding:10px 14px;cursor:pointer;white-space:nowrap;transition:all .2s;}
  .nav-btn:hover{color:var(--green);background:#00ff4108;}
  .nav-btn.active{color:var(--green);background:#001f00;border-bottom:2px solid var(--green);}
  .badge-new{background:var(--red);color:#fff;font-size:8px;padding:1px 4px;margin-left:4px;vertical-align:middle;}
  .content{padding:20px;max-width:1400px;margin:0 auto;}
  .tab-panel{display:none;}.tab-panel.active{display:block;}
  .section-title{font-family:'Orbitron',sans-serif;font-size:16px;font-weight:700;color:var(--green);text-shadow:var(--glow);margin-bottom:20px;display:flex;align-items:center;gap:10px;}
  .section-title::after{content:'';flex:1;height:1px;background:linear-gradient(90deg,#00ff4144,transparent);}
  .terminal{background:#000;border:1px solid #00ff4144;font-family:'Share Tech Mono',monospace;font-size:13px;color:var(--green);padding:14px;height:240px;overflow-y:auto;}
  .terminal-line{margin:2px 0;}.terminal-line.cmd{color:var(--cyan);}.terminal-line.err{color:var(--red);}.terminal-line.warn{color:var(--yellow);}.terminal-line.success{color:#00ff41;}
  .terminal-input-row{display:flex;align-items:center;gap:8px;margin-top:8px;}
  .term-input{flex:1;background:transparent;border:none;color:var(--green);font-family:'Share Tech Mono',monospace;font-size:13px;outline:none;}
  .cards-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:14px;margin-bottom:20px;}
  .card{background:var(--panel);border:1px solid #00ff4122;padding:18px;transition:all .2s;cursor:pointer;}
  .card:hover{border-color:#00ff4166;box-shadow:0 0 15px #00ff4111;}
  .card-title{font-family:'Orbitron',sans-serif;font-size:12px;color:var(--green);margin-bottom:8px;letter-spacing:2px;}
  .card-icon{font-size:24px;margin-bottom:8px;display:block;}
  .btn{background:transparent;border:1px solid var(--green);color:var(--green);font-family:'Share Tech Mono',monospace;font-size:12px;padding:7px 16px;cursor:pointer;transition:all .2s;}
  .btn:hover{background:#00ff4122;}
  .btn-cyan{border-color:var(--cyan);color:var(--cyan);}.btn-cyan:hover{background:#00eeff22;}
  .btn-red{border-color:var(--red);color:var(--red);}.btn-red:hover{background:#ff003c22;}
  .btn-yellow{border-color:var(--yellow);color:var(--yellow);}
  .btn-full{width:100%;text-align:center;}
  .form-row{margin-bottom:12px;}
  .form-row label{display:block;font-size:10px;color:#00ff4188;margin-bottom:4px;letter-spacing:2px;}
  .form-input{width:100%;background:#001500;border:1px solid #00ff4144;color:var(--green);font-family:'Share Tech Mono',monospace;font-size:12px;padding:8px 10px;outline:none;}
  .form-input:focus{border-color:var(--green);}
  .form-select{width:100%;background:#001500;border:1px solid #00ff4144;color:var(--green);font-family:'Share Tech Mono',monospace;font-size:12px;padding:8px 10px;outline:none;}
  .output-box{background:#000;border:1px solid #00ff4133;padding:12px;font-size:12px;color:var(--cyan);min-height:50px;word-break:break-all;margin-top:10px;font-family:'Share Tech Mono',monospace;line-height:1.7;}
  .two-col{display:grid;grid-template-columns:1fr 1fr;gap:18px;}
  .three-col{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;}
  .strength-bar{height:5px;background:#002200;border-radius:3px;margin-top:8px;overflow:hidden;}
  .strength-fill{height:100%;border-radius:3px;transition:width .4s,background .4s;}
  .scan-table{width:100%;border-collapse:collapse;font-size:11px;margin-top:10px;}
  .scan-table th{background:#001f00;border:1px solid #00ff4133;padding:7px 10px;color:var(--green);font-family:'Orbitron',sans-serif;font-size:10px;text-align:left;}
  .scan-table td{border:1px solid #00ff4122;padding:7px 10px;color:#00ff41cc;}
  .secure{color:#00ff41;}.weak{color:var(--yellow);}.vuln{color:var(--red);}
  .chat-box{background:#000;border:1px solid #00ff4133;height:380px;overflow-y:auto;padding:14px;margin-bottom:10px;font-size:12px;}
  .chat-msg{margin-bottom:12px;}
  .chat-msg .from{font-size:9px;letter-spacing:3px;margin-bottom:3px;}
  .chat-msg.user .from{color:var(--cyan);}.chat-msg.ai .from{color:var(--green);}
  .chat-msg .text{line-height:1.7;padding:8px 12px;border-left:2px solid;}
  .chat-msg.user .text{color:var(--cyan);border-color:var(--cyan);background:#001a1f;}
  .chat-msg.ai .text{color:var(--green);border-color:var(--green);background:#001500;}
  .chat-input-row{display:flex;gap:8px;}
  .chat-input{flex:1;background:#001500;border:1px solid #00ff4144;color:var(--green);font-family:'Share Tech Mono',monospace;font-size:12px;padding:9px 12px;outline:none;}
  .ai-typing{color:#00ff4166;font-size:11px;letter-spacing:2px;margin-top:6px;}
  .game-area{background:#000;border:1px solid #00ff4144;padding:20px;text-align:center;}
  .game-title{font-family:'VT323',monospace;font-size:34px;color:var(--green);text-shadow:var(--glow);margin-bottom:6px;}
  .game-grid{display:inline-grid;gap:3px;margin:0 auto 16px;}
  .game-cell{width:40px;height:40px;border:1px solid #00ff4133;display:flex;align-items:center;justify-content:center;font-size:16px;cursor:pointer;transition:all .15s;background:#001500;color:var(--green);}
  .game-cell:hover{border-color:var(--green);background:#002500;}
  .game-cell.revealed{background:#002000;cursor:default;}
  .game-cell.mine{background:#1a0000;border-color:var(--red);}
  .game-cell.flagged{background:#1a1000;border-color:var(--yellow);}
  .game-stats{display:flex;gap:20px;justify-content:center;font-family:'Orbitron',sans-serif;font-size:13px;margin-bottom:14px;color:var(--green);}
  .game-controls{display:flex;gap:8px;justify-content:center;}
  .progress-bar{height:6px;background:#002200;margin-top:6px;border-radius:3px;overflow:hidden;}
  .progress-fill{height:100%;background:var(--green);transition:width .3s;}
  .stat-row{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:20px;}
  .stat-card{background:var(--panel);border:1px solid #00ff4122;padding:14px;text-align:center;}
  .stat-num{font-family:'Orbitron',sans-serif;font-size:24px;color:var(--green);text-shadow:var(--glow);}
  .stat-lbl{font-size:9px;color:#00ff4166;letter-spacing:2px;margin-top:3px;}
  /* PACKET ANALYZER */
  .packet{padding:6px 10px;border-left:3px solid;margin-bottom:4px;font-size:11px;animation:fadeIn .3s;}
  .packet-tcp{border-color:var(--green);background:#001500;}
  .packet-udp{border-color:var(--cyan);background:#001a1f;}
  .packet-http{border-color:var(--yellow);background:#1a1000;}
  .packet-dns{border-color:#aa44ff;background:#0a0015;}
  .packet-arp{border-color:var(--red);background:#1a0000;}
  @keyframes fadeIn{from{opacity:0;transform:translateX(-10px)}to{opacity:1;transform:translateX(0)}}
  /* CTF */
  .ctf-challenge{background:#001500;border:1px solid #00ff4122;padding:14px;margin-bottom:12px;}
  .ctf-title{font-family:'Orbitron',sans-serif;font-size:12px;color:var(--cyan);margin-bottom:6px;}
  .ctf-points{color:var(--yellow);font-size:11px;}
  .ctf-solved{border-color:var(--green);background:#002200;}
  /* VULN SCANNER */
  .vuln-item{padding:8px 12px;border-left:3px solid;margin-bottom:6px;font-size:11px;}
  .vuln-critical{border-color:var(--red);background:#1a0000;}
  .vuln-high{border-color:var(--yellow);background:#1a1000;}
  .vuln-medium{border-color:var(--cyan);background:#001a1a;}
  .vuln-low{border-color:var(--green);background:#001500;}
  /* EXPLOIT DB */
  .exploit-card{background:#0a0a0a;border:1px solid #00ff4122;padding:12px;margin-bottom:8px;cursor:pointer;transition:all .2s;}
  .exploit-card:hover{border-color:var(--green);background:#001500;}
  .exploit-tag{display:inline-block;font-size:9px;padding:1px 5px;margin-right:4px;}
  .tag-critical{background:#3a0000;border:1px solid var(--red);color:var(--red);}
  .tag-high{background:#2a1000;border:1px solid var(--yellow);color:var(--yellow);}
  .tag-medium{background:#002020;border:1px solid var(--cyan);color:var(--cyan);}
  /* CIPHER */
  .cipher-tabs{display:flex;gap:0;margin-bottom:14px;border-bottom:1px solid #00ff4122;}
  .cipher-tab{background:transparent;border:none;border-bottom:2px solid transparent;color:#00ff4166;font-family:'Share Tech Mono',monospace;font-size:11px;padding:7px 14px;cursor:pointer;transition:all .2s;}
  .cipher-tab.active{color:var(--green);border-bottom-color:var(--green);}
  .cipher-panel{display:none;}.cipher-panel.active{display:block;}
  /* DARK WEB MONITOR */
  .breach-item{padding:8px 12px;border:1px solid #00ff4122;margin-bottom:6px;font-size:11px;}
  .breach-found{border-color:var(--red);background:#1a0000;}
  .breach-safe{border-color:var(--green);background:#001500;}
  /* RECON */
  .recon-result{background:#000;border:1px solid #00ff4133;padding:12px;font-size:11px;color:var(--cyan);margin-top:10px;min-height:80px;line-height:1.8;}
  /* NETWORK MAP */
  #netmap-canvas{background:#000;border:1px solid #00ff4144;width:100%;height:300px;}
  @keyframes glitch{0%{text-shadow:2px 0 var(--red),-2px 0 var(--cyan);}50%{text-shadow:-2px 0 var(--red),2px 0 var(--cyan);}100%{text-shadow:2px 0 var(--red),-2px 0 var(--cyan);}}
  .glitch{animation:glitch 3s infinite;}
  @keyframes blink{50%{opacity:0;}}.blink{animation:blink 1s step-end infinite;}
  @media(max-width:700px){.stat-row{grid-template-columns:repeat(2,1fr);}.login-box{width:95vw;padding:24px 16px;}.content{padding:12px;}.two-col,.three-col{grid-template-columns:1fr;}}
  ::-webkit-scrollbar{width:5px;}::-webkit-scrollbar-track{background:#000;}::-webkit-scrollbar-thumb{background:#00ff4133;}
  .threat-item{display:flex;align-items:center;gap:10px;padding:8px 12px;border:1px solid;margin-bottom:6px;font-size:11px;}
  .t-critical{border-color:var(--red);background:#1a0000;color:var(--red);}
  .t-high{border-color:var(--yellow);background:#1a1000;color:var(--yellow);}
  .t-medium{border-color:var(--cyan);background:#001a1a;color:var(--cyan);}
  .t-low{border-color:var(--green);background:#001500;color:var(--green);}
  textarea.form-input{resize:vertical;min-height:80px;}
</style>
</head>
<body>
<canvas id="matrix-canvas"></canvas>

<!-- LOGIN -->
<div id="login-screen">
  <div class="login-box">
    <div class="login-logo">&#9889; SANDESH ETH-HACK</div>
    <div class="login-sub">ADVANCED ETHICAL HACKING SUITE v4.0</div>
    <div class="login-field"><label>&#9658; USERNAME / EMAIL</label><input type="text" id="login-user" placeholder="root@sandesh.local" autocomplete="off"></div>
    <div class="login-field"><label>&#9658; PASSWORD</label><input type="password" id="login-pass" placeholder="••••••••••••" onkeydown="if(event.key==='Enter')doLogin()"></div>
    <button class="login-btn" onclick="doLogin()">[ AUTHENTICATE ]</button>
    <button class="gmail-btn" onclick="gmailLogin()"><span>G</span> SIGN IN WITH GMAIL</button>
    <div class="login-status" id="login-status"></div>
  </div>
</div>

<!-- APP -->
<div id="app">
  <div class="header">
    <div class="header-logo">&#9889; <span>SANDESH</span> ETHICAL HACKING SUITE v4.0</div>
    <div style="font-size:10px;color:#00ff4177"><span class="blink">&#9679;</span> LIVE</div>
    <div class="user-badge" id="user-badge">root</div>
    <button class="logout-btn" onclick="logout()">LOGOUT</button>
  </div>
  <div class="nav">
    <button class="nav-btn active" onclick="showTab('dashboard')">&#8962; DASHBOARD</button>
    <button class="nav-btn" onclick="showTab('terminal')">$ TERMINAL</button>
    <button class="nav-btn" onclick="showTab('passgen')">&#128273; PASSWORDS</button>
    <button class="nav-btn" onclick="showTab('recon')">&#128269; RECON</button>
    <button class="nav-btn" onclick="showTab('scanner')">&#128163; VULN SCAN<span class="badge-new">NEW</span></button>
    <button class="nav-btn" onclick="showTab('packets')">&#128225; PACKETS<span class="badge-new">NEW</span></button>
    <button class="nav-btn" onclick="showTab('netmap')">&#127760; NET MAP<span class="badge-new">NEW</span></button>
    <button class="nav-btn" onclick="showTab('ctf')">&#127942; CTF LAB<span class="badge-new">NEW</span></button>
    <button class="nav-btn" onclick="showTab('darkweb')">&#128565; DARK WEB<span class="badge-new">NEW</span></button>
    <button class="nav-btn" onclick="showTab('exploit')">&#128296; EXPLOITS</button>
    <button class="nav-btn" onclick="showTab('cipher')">&#128272; CIPHER</button>
    <button class="nav-btn" onclick="showTab('wifi')">&#128246; WIFI</button>
    <button class="nav-btn" onclick="showTab('network')">&#128290; NETWORK</button>
    <button class="nav-btn" onclick="showTab('ai')">&#129302; AI</button>
    <button class="nav-btn" onclick="showTab('game')">&#127918; GAME</button>
  </div>
  <div class="content">

    <!-- DASHBOARD -->
    <div class="tab-panel active" id="tab-dashboard">
      <div class="section-title glitch">COMMAND CENTER</div>
      <div class="stat-row">
        <div class="stat-card"><div class="stat-num" id="stat-scans">0</div><div class="stat-lbl">SCANS</div></div>
        <div class="stat-card"><div class="stat-num" id="stat-pass">0</div><div class="stat-lbl">PASSWORDS</div></div>
        <div class="stat-card"><div class="stat-num" id="stat-ctf">0</div><div class="stat-lbl">CTF SOLVED</div></div>
        <div class="stat-card"><div class="stat-num" id="stat-score">0</div><div class="stat-lbl">SCORE</div></div>
      </div>
      <div class="two-col">
        <div>
          <div class="terminal" id="dash-term"></div>
          <div style="margin-top:16px">
            <div class="section-title" style="font-size:13px">&#9889; THREAT INTELLIGENCE FEED</div>
            <div id="threat-feed"></div>
          </div>
        </div>
        <div>
          <div class="section-title" style="font-size:13px">&#128203; QUICK LAUNCH</div>
          <div class="cards-grid" style="grid-template-columns:1fr 1fr">
            <div class="card" onclick="showTab('scanner')"><span class="card-icon">&#128163;</span><div class="card-title">VULN SCANNER</div><div style="font-size:11px;color:#00ff4188">Advanced scanning</div></div>
            <div class="card" onclick="showTab('packets')"><span class="card-icon">&#128225;</span><div class="card-title">PACKET ANALYZER</div><div style="font-size:11px;color:#00ff4188">Live traffic</div></div>
            <div class="card" onclick="showTab('ctf')"><span class="card-icon">&#127942;</span><div class="card-title">CTF CHALLENGES</div><div style="font-size:11px;color:#00ff4188">10 challenges</div></div>
            <div class="card" onclick="showTab('darkweb')"><span class="card-icon">&#128565;</span><div class="card-title">DARK WEB MONITOR</div><div style="font-size:11px;color:#00ff4188">Breach checker</div></div>
            <div class="card" onclick="showTab('netmap')"><span class="card-icon">&#127760;</span><div class="card-title">NETWORK MAP</div><div style="font-size:11px;color:#00ff4188">Visual topology</div></div>
            <div class="card" onclick="showTab('ai')"><span class="card-icon">&#129302;</span><div class="card-title">AI ASSISTANT</div><div style="font-size:11px;color:#00ff4188">Ask anything</div></div>
          </div>
        </div>
      </div>
    </div>

    <!-- TERMINAL -->
    <div class="tab-panel" id="tab-terminal">
      <div class="section-title">KALI LINUX TERMINAL</div>
      <div class="terminal" id="main-term"></div>
      <div class="terminal-input-row">
        <span style="color:var(--green);font-size:13px;white-space:nowrap">&#9484;&#9472;&#9472;(root&#9753;sandesh)-[~]<br>&#9492;&#9472;$&nbsp;</span>
        <input class="term-input" id="term-input" placeholder="type command..." onkeydown="handleTermKey(event)" autocomplete="off" spellcheck="false">
      </div>
    </div>

    <!-- PASSWORD GENERATOR -->
    <div class="tab-panel" id="tab-passgen">
      <div class="section-title">PASSWORD GENERATOR</div>
      <div class="two-col">
        <div>
          <div class="form-row"><label>LENGTH</label><input class="form-input" type="number" id="pass-len" value="24" min="6" max="128"></div>
          <div class="form-row"><label>SETS</label>
            <div style="display:flex;flex-direction:column;gap:6px;padding:10px;background:#001500;border:1px solid #00ff4122">
              <label style="display:flex;align-items:center;gap:8px;font-size:12px;color:var(--green);cursor:pointer"><input type="checkbox" id="use-upper" checked style="accent-color:var(--green)"> UPPERCASE A-Z</label>
              <label style="display:flex;align-items:center;gap:8px;font-size:12px;color:var(--green);cursor:pointer"><input type="checkbox" id="use-lower" checked style="accent-color:var(--green)"> LOWERCASE a-z</label>
              <label style="display:flex;align-items:center;gap:8px;font-size:12px;color:var(--green);cursor:pointer"><input type="checkbox" id="use-nums" checked style="accent-color:var(--green)"> NUMBERS 0-9</label>
              <label style="display:flex;align-items:center;gap:8px;font-size:12px;color:var(--green);cursor:pointer"><input type="checkbox" id="use-sym" checked style="accent-color:var(--green)"> SYMBOLS !@#$%</label>
            </div>
          </div>
          <div class="form-row"><label>QUANTITY</label><input class="form-input" type="number" id="pass-qty" value="5" min="1" max="20"></div>
          <div class="form-row"><label>MODE</label><select class="form-select" id="pass-mode"><option value="random">RANDOM</option><option value="passphrase">PASSPHRASE</option><option value="pin">PIN</option></select></div>
          <button class="btn btn-full" onclick="generatePasswords()">&#9889; GENERATE</button>
