let netmapCanvas,netmapCtx,netNodes=[];
function initNetMapCanvas(){
  netmapCanvas=document.getElementById('netmap-canvas');
  netmapCtx=netmapCanvas.getContext('2d');
  netmapCanvas.width=netmapCanvas.offsetWidth;
  netmapCanvas.height=netmapCanvas.offsetHeight||300;
  drawEmptyNet();
}
function drawEmptyNet(){
  if(!netmapCtx)return;
  netmapCtx.fillStyle='#000';
  netmapCtx.fillRect(0,0,netmapCanvas.width,netmapCanvas.height);
  netmapCtx.fillStyle='#00ff4133';
  netmapCtx.font='12px Share Tech Mono';
  netmapCtx.textAlign='center';
  netmapCtx.fillText('Click DISCOVER NETWORK to map topology',netmapCanvas.width/2,netmapCanvas.height/2);
}
function runNetMap(){
  const btn=document.getElementById('netmap-btn');btn.disabled=true;btn.textContent='SCANNING...';
  let pct=0;const iv=setInterval(()=>{pct+=Math.random()*10;if(pct>100)pct=100;document.getElementById('netmap-progress').style.width=pct+'%';
    if(pct>=100){clearInterval(iv);btn.disabled=false;btn.textContent='DISCOVER NETWORK';buildNetMap();}},200);
}
function buildNetMap(){
  const hosts=[
    {ip:'192.168.1.1',name:'Router/Gateway',type:'router',open:[80,443,22]},
    {ip:'192.168.1.5',name:'Windows PC',type:'windows',open:[135,445,3389]},
    {ip:'192.168.1.10',name:'Linux Server',type:'linux',open:[22,80,443,8080]},
    {ip:'192.168.1.15',name:'Android Phone',type:'mobile',open:[5555]},
    {ip:'192.168.1.20',name:'Smart TV',type:'iot',open:[8008,9080]},
    {ip:'192.168.1.25',name:'IP Camera',type:'iot',open:[80,554,8000]},
    {ip:'192.168.1.100',name:'Kali (You)',type:'kali',open:[22,4444]},
  ];
  document.getElementById('netmap-hosts').innerHTML=hosts.map(h=>`<div style="padding:5px 8px;border-left:2px solid ${h.type==='router'?'#ffe600':h.type==='kali'?'#00eeff':h.type==='iot'?'#ff003c':'#00ff41'};margin-bottom:4px;font-size:11px"><span style="color:${h.type==='iot'?'var(--red)':'var(--green)'}">${h.ip}</span> — ${h.name}<br><span style="color:#00ff4166">Ports: ${h.open.join(', ')}</span></div>`).join('');
  if(!netmapCtx){initNetMapCanvas();}
  netmapCtx.fillStyle='#000';netmapCtx.fillRect(0,0,netmapCanvas.width,netmapCanvas.height);
  const cx=netmapCanvas.width/2,cy=netmapCanvas.height/2;
  const colors={router:'#ffe600',windows:'#00aaff',linux:'#00ff41',mobile:'#ff6600',iot:'#ff003c',kali:'#00eeff'};
  hosts.forEach((h,i)=>{
    const angle=(i/hosts.length)*Math.PI*2-Math.PI/2;
    const r=i===0?0:Math.min(cx,cy)*0.7;
    h.x=cx+r*Math.cos(angle);h.y=cy+r*Math.sin(angle);
  });
  hosts.forEach(h=>{
    if(h.type!=='router'&&hosts[0]){
      netmapCtx.beginPath();netmapCtx.moveTo(hosts[0].x,hosts[0].y);netmapCtx.lineTo(h.x,h.y);
      netmapCtx.strokeStyle='#00ff4133';netmapCtx.lineWidth=1;netmapCtx.setLineDash([4,4]);netmapCtx.stroke();netmapCtx.setLineDash([]);
    }
  });
  hosts.forEach(h=>{
    netmapCtx.beginPath();netmapCtx.arc(h.x,h.y,18,0,Math.PI*2);
    netmapCtx.fillStyle=colors[h.type]+'33';netmapCtx.fill();
    netmapCtx.strokeStyle=colors[h.type];netmapCtx.lineWidth=2;netmapCtx.stroke();
    netmapCtx.fillStyle=colors[h.type];netmapCtx.font='bold 10px Share Tech Mono';netmapCtx.textAlign='center';
    netmapCtx.fillText(h.ip.split('.')[3],h.x,h.y+3);
    netmapCtx.fillStyle='#00ff4199';netmapCtx.font='10px Share Tech Mono';
    netmapCtx.fillText(h.name,h.x,h.y+32);
  });
}

