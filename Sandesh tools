function startCapture(){
  const filter=document.getElementById('pkt-filter').value;
  pktStats={tcp:0,udp:0,http:0,dns:0,arp:0,total:0};
  document.getElementById('packet-feed').innerHTML='';
  document.getElementById('pkt-alerts').textContent='';
  document.getElementById('cap-btn').disabled=true;
  document.getElementById('stop-btn').disabled=false;
  document.getElementById('cap-indicator').style.display='inline';
  captureInterval=setInterval(()=>{
    const pkt=PACKET_TYPES[Math.floor(Math.random()*PACKET_TYPES.length)];
    if(filter!=='all'&&pkt.type!==filter)return;
    pktStats[pkt.type]=(pktStats[pkt.type]||0)+1;pktStats.total++;
    updatePktStats();
    const feed=document.getElementById('packet-feed');
    const d=document.createElement('div');
    d.className='packet packet-'+pkt.type;
    const time=new Date().toTimeString().split(' ')[0];
    d.innerHTML=`<span style="color:#00ff4166">${time}</span> <span style="color:${pkt.type==='arp'?'var(--red)':pkt.type==='http'?'var(--yellow)':pkt.type==='dns'?'#aa44ff':pkt.type==='udp'?'var(--cyan)':'var(--green)'}">[${pkt.type.toUpperCase()}]</span> ${pkt.src}:${pkt.sport} → ${pkt.dst}:${pkt.dport} <span style="color:#aaa">${pkt.info}</span> <span style="color:#00ff4155">${pkt.size}B</span>`;
    feed.appendChild(d);feed.scrollTop=feed.scrollHeight;
    if(pkt.alert){const alerts=document.getElementById('pkt-alerts');alerts.textContent+='⚠ '+pkt.info+'\n';}
  },600);
}
function stopCapture(){
  clearInterval(captureInterval);
  document.getElementById('cap-btn').disabled=false;
  document.getElementById('stop-btn').disabled=true;
  document.getElementById('cap-indicator').style.display='none';
}
function updatePktStats(){
  document.getElementById('s-tcp').textContent=pktStats.tcp||0;
  document.getElementById('s-udp').textContent=pktStats.udp||0;
  document.getElementById('s-http').textContent=pktStats.http||0;
  document.getElementById('s-dns').textContent=pktStats.dns||0;
  document.getElementById('s-arp').textContent=pktStats.arp||0;
  document.getElementById('s-total').textContent=pktStats.total;
}

